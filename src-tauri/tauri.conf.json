{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "journey",
  "version": "0.1.0",
  "identifier": "com.leucht.journey",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "journey",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:dev.db"]
    }
  }
}
