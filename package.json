{
  "name": "journey",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "dx prettier --write .",
    "tauri": "tauri",
    "generate": "dx drizzle-kit generate && deno ./src/lib/db/compile-migrations.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@jellyfin/sdk": "^0.13.0",
    "@sveltejs/adapter-static": "4.0.0-next.0",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/kit": "3.0.0-next.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "@types/node": "26.0.0",
    "@videojs/html": "^10.0.0-beta.24",
    "clsx": "^2.1.1",
    "drizzle-kit": "^1.0.0-rc.4-ca0f029",
    "drizzle-orm": "^1.0.0-rc.4-5d5b77c",
    "lru-cache": "^11.5.1",
    "prettier": "^3.8.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.1-rc",
    "uuid": "^14.0.1",
    "vitest": "5.0.0-beta.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.3",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "vite": "^8.1.0"
  }
}
